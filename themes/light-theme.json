      "settings": {
        "foreground": "#C7A062"
      }
    },
    {
      "name": "CSS ID's",
      "scope": [
        "source.sass keyword.control",
        "meta.attribute-selector.scss"
      ],
      "settings": {
        "foreground": "#37BB8A"
